# Copy to .env only if your process manager loads dotenv files, or export these
# values in the shell/systemd environment before starting the server.
HOST=127.0.0.1
PORT=3168
NODE_ENV=development

# Required to enable the administrator login on a fresh database.
BENCHMARK_ADMIN_PASSWORD=replace-with-a-long-random-password

# Recommended stable encryption key for persisted provider API keys.
BENCHMARK_SECRET=replace-with-at-least-32-random-characters
